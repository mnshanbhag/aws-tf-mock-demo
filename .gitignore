# Terraform state and local data
terraform.tfstate
terraform.tfstate.backup
terraform.tfvars
*.tfplan

# Terraform plugin cache and lock
.terraform/
# Keep the lock file — it pins provider versions
!.terraform.lock.hcl

# LocalStack persistence volume
.localstack/

# Lambda build artefact — generated by archive_file at plan time
modules/lambda/handler.zip

# Python test venv (already covered by .venv/ but explicit is clearer)
.venv/

# Python bytecode cache
__pycache__/
*.pyc
*.pyo

# OS / editor noise
.DS_Store
*.swp
